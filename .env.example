# Banco Supabase (Project Settings → Database → Connection string)
# Runtime na Vercel: use o Connection Pooler / Transaction (porta 6543).
DATABASE_URL="postgresql://postgres.PROJECT:SENHA@aws-0-REGIAO.pooler.supabase.com:6543/postgres?sslmode=require"

# Migrations/seed (drizzle-kit): use a conexão direta ou Session pooler (porta 5432).
# Se preferir, pode usar a mesma DATABASE_URL acima para o seed.
DIRECT_URL="postgresql://postgres.PROJECT:SENHA@aws-0-REGIAO.pooler.supabase.com:5432/postgres?sslmode=require"

# Vercel Blob (Storage > Blob > Tokens). Em produção é injetado automaticamente.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Auth.js — gere com: npx auth secret  (ou openssl rand -base64 32)
AUTH_SECRET="troque-por-um-segredo-forte"

# Seed do tesoureiro admin (usado só pelo script de seed)
ADMIN_EMAIL="tesoureiro@org.org"
ADMIN_PASSWORD="troque-esta-senha"
ADMIN_NAME="Tesoureiro"
